<?xml version='1.0' encoding='utf-8'?>
<!--
  AI Marketing Allocation Engine - Tableau workbook (source artifact).
  Matches Tableau Desktop 2025.3.x workbook XML. Point the text connection at data/ CSVs after open.
  GitHub Linguist counts .twb as XML (no separate Tableau language on the language bar).
-->
<workbook original-version='2025.3' source-build='20253.26.0109.0333' source-platform='win'
          version='18.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <document-format-change-manifest>
    <ManifestByVersion />
  </document-format-change-manifest>
  <preferences>
  </preferences>
  <datasources>
    <datasource hasconnection='false' inline='true' name='Parameters' version='18.1'>
      <aliases enabled='yes' />
    </datasource>
    <datasource caption='Allocation pressure model' inline='true' name='allocation_model' version='18.1'>
      <connection class='textscan' directory='../data' filename='dataset4_allocation_pressure_model.csv' password='' server='' />
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sheet 1'>
      <layout-options>
        <title>
          <formatted-text />
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource name='allocation_model' />
          </datasources>
          <aggregation value='true' />
        </view>
        <simple-id uuid='{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}' />
      </table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Net Allocation Pressure'>
      <style />
      <size maxheight='800' maxwidth='1280' minheight='600' minwidth='800' />
      <zones>
        <zone h='100000' id='1' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='95000' id='2' mode='dashboard' name='Sheet 1' w='95000' x='2500' y='2500' type-v2='sheet'>
            <layout fixed='true' />
          </zone>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
